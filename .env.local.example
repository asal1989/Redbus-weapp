# ─────────────────────────────────────────────
# Google Sheets — Bus Trip Data Source
# ─────────────────────────────────────────────

# Option A (Recommended for public sheets):
# 1. Open your Google Sheet
# 2. File → Share → Publish to web → Sheet1 → CSV → Publish
# 3. Copy the URL and paste it here
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv

# Option B (For private sheets — requires Google Sheets API key):
# GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# GOOGLE_SHEETS_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────
# Razorpay — Payment Links
# ─────────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─────────────────────────────────────────────
# App URL (used for Razorpay redirect after payment)
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-site.netlify.app

# ─────────────────────────────────────────────
# Email Notifications (SMTP)
# ─────────────────────────────────────────────
# For Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password

# Email address that receives new booking notifications
NOTIFY_EMAIL=operator@yourcompany.com
